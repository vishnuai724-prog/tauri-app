{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QLIMS",
  "version": "0.1.5",
  "identifier": "com.vishn.qlims",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QLIMS",
        "label": "main",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost http://localhost:* https://*.yourdomain.com https://github.com https://*.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vishnuai724-prog/tauri-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwMUMxODNBMjMzRTVFQzkKUldUSlhqNGpPaGdjY0F1SXcxaVBTMjMreU52VWllSVZPU1ZxUEU1OS9yaytaSlhTdWZUR2ZjN3kK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "A cross-platform Tauri application",
    "longDescription": "An enterprise-grade cross-platform desktop application built with Tauri 2, React, and TypeScript.",
    "copyright": "Copyright © 2026 vishn. All rights reserved.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}