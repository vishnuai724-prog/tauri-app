{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "jsxSingleQuote": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "src-tauri/target",
    "src-tauri/gen",
    "package-lock.json",
    "*.lock"
  ]
}
